<Window x:Class="LLM_IDE.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:md="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
        Title="Ra_LLM_IDE" Height="800" Width="1400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Height="25" Background="White">
            <MenuItem Header="파일(F)"/>
            <MenuItem Header="설정(S)"/>
            <MenuItem Header="계정(_A)">
                <MenuItem x:Name="menuLogin" Header="Gemini 로그인(_L)" Click="menuLogin_Click"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" Background="White">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" x:Name="ProjectCol"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1" x:Name="EngineCol"/>
            </Grid.ColumnDefinitions>

            <TabControl Grid.Column="0">
                <TabItem Header="세션 목록">
                    <DockPanel Background="#2D2D2D">
                        <Button Content="세션 새로고침" Click="btnRefresh_Click" DockPanel.Dock="Top" Margin="5"/>
                        <ListBox x:Name="SessionList" DisplayMemberPath="Title" SelectionChanged="SessionList_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                    </DockPanel>
                </TabItem>
                <TabItem Header="프로젝트 설정" x:Name="TabProjectSet">
                    <Grid Background="#F9F9F9">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBox x:Name="TxtProjectEditor" Grid.Row="0" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="5" Padding="10" FontSize="12" BorderBrush="#DDDDDD" />
                        <Button x:Name="BtnProjectSave" Grid.Row="1" Content="설정 저장" Height="30" Margin="5" Background="#10b981" Foreground="White" FontWeight="Bold" Click="BtnProjectSave_Click"/>
                    </Grid>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#DDDDDD"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" MinHeight="200"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="100"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox x:Name="LogList" Grid.Row="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch" ScrollViewer.CanContentScroll="False" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding TimeStamp}" TextWrapping="Wrap" Foreground="Gray" FontSize="11" Padding="5"/>
                                <TextBlock Grid.Column="1" Text="{Binding UserInput}" TextWrapping="Wrap" FontWeight="SemiBold" Padding="5"/>
                                <Border Grid.Column="2" Background="#F0F7FF" CornerRadius="5" Padding="5" Margin="5,0">
                                    <md:MarkdownViewer Markdown="{Binding LlmOutput, Mode=OneWay}" FontSize="10" FontFamily="Consolas" Background="Transparent" PreviewMouseWheel="rcvMsg_PreviewMouseWheel" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                        <md:MarkdownViewer.Resources>
                                            <Style TargetType="{x:Type Paragraph}">
                                                <Setter Property="FontSize" Value="10" />
                                                <Setter Property="Margin" Value="0,2,0,2" />
                                            </Style>
                                            <Style TargetType="{x:Type Table}">
                                                <Setter Property="CellSpacing" Value="0" />
                                                <Setter Property="Margin" Value="0,5,0,5" />
                                            </Style>
                                            <Style TargetType="{x:Type TableCell}">
                                                <Setter Property="Padding" Value="5,2,5,2" />
                                                <Setter Property="BorderThickness" Value="0.5" />
                                                <Setter Property="BorderBrush" Value="#DDDDDD" />
                                            </Style>
                                        </md:MarkdownViewer.Resources>
                                    </md:MarkdownViewer>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="1" Background="#F0F0F0">
                    <Button x:Name="BtnSave" Content="Save Log" Width="100" HorizontalAlignment="Right" Margin="5" Click="BtnSave_Click"/>
                </Grid>

                <ScrollViewer Grid.Row="2" 
              HorizontalScrollBarVisibility="Auto" 
              VerticalScrollBarVisibility="Disabled"
              Background="#F9F9F9"
              Margin="10,0,10,0"
              BorderBrush="#CCCCCC"
              BorderThickness="1,1,1,0"
              Visibility="Collapsed" 
              x:Name="FilePreviewArea"
              Height="45">
                    <ItemsControl x:Name="FileItemsControl" Margin="5">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#E1F5FE" CornerRadius="4" Margin="3" Padding="8,2" BorderBrush="#0288D1" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding FileName}" VerticalAlignment="Center" FontSize="11" Foreground="#01579B" Margin="0,0,8,0"/>
                                        <Button Content="✕" 
                                Click="BtnDeleteFile_Click" 
                                Tag="{Binding}" 
                                Background="Transparent" 
                                BorderThickness="0" 
                                Cursor="Hand" 
                                Foreground="#D32F2F" 
                                FontWeight="Bold" 
                                FontSize="12"
                                VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBox x:Name="TxtInput" 
                         Grid.Row="3" 
                         AcceptsReturn="True" 
                         TextWrapping="Wrap" 
                         VerticalScrollBarVisibility="Auto" 
                         Margin="10" 
                         Padding="5" 
                         FontSize="13" 
                         BorderBrush="#CCCCCC" 
                         BorderThickness="1"
                         AllowDrop="True"
                         PreviewDragOver="TxtInput_PreviewDragOver"
                         Drop="TxtInput_Drop"/>

                <Grid Grid.Row="4" Margin="5">
                    <Button x:Name="BtnShowWeb" Content="Open" Width="50" Margin="5" HorizontalAlignment="Left" Click="BtnShowWeb_Click"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnSend" Content="Send (Ctrl+Enter)" Width="120" Margin="5" Background="#2563EB" Foreground="White" FontWeight="Bold" Click="BtnSend_Click"/>
                        <Button x:Name="BtnHandoff" Content="Handoff" Width="100" Margin="5" Click="btnHandoff_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Column="3" x:Name="EngineWrapper" Background="Transparent" ClipToBounds="True" Panel.ZIndex="-1">
                <wv2:WebView2 x:Name="MainWebView" Width="100" Height="768" Source="https://gemini.google.com" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            </Grid>
        </Grid>
    </Grid>
</Window>